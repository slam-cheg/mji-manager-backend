# Copy to .env and fill secrets. Restart backend after changes.

NODE_ENV=development
HOST=0.0.0.0
PORT=2010

# --- Database ---
DB_HOST=200.0.0.100
DB_PORT=3001
DB_NAME=Manager
DB_USER=postgres
DB_PASSWORD=

# --- ExpertHub SSO (backend exchanges OAuth code with Hub) ---
# Hub URL: prod https://hub.sste.ru or local http://localhost:3000
EXPERT_HUB_SSO_URL=https://hub.sste.ru
EXPERT_HUB_SSO_CLIENT_ID=mji-manager
# Shared secret from corporate-app Hub (EXPERT_HUB_SSO_CLIENT_SECRET)
EXPERT_HUB_SSO_CLIENT_SECRET=
EXPERT_HUB_FETCH_TIMEOUT_MS=30000

# --- JWT & session cookies ---
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Comma-separated OAuth redirect_uri values registered for this app.
# Web: {origin}/auth/expert-hub/callback
# Extension (dev, tab OAuth): http://localhost:2010/auth/experthub/extension-callback
# Extension (prod): https://<extension-id>.chromiumapp.org/ (add after loading ext in chrome://extensions)
OAUTH_REDIRECT_URIS=http://localhost:3000/auth/expert-hub/callback,http://127.0.0.1:3000/auth/expert-hub/callback,http://localhost:2010/auth/experthub/extension-callback,http://127.0.0.1:2010/auth/experthub/extension-callback,https://mjimanager.ru/auth/expert-hub/callback

# Comma-separated browser origins allowed for CORS (must include frontend URL)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.0.133:3000,https://mjimanager.ru

# Cookie policy: lax for local dev; strict/none for prod behind HTTPS
AUTH_COOKIE_SAMESITE=lax
AUTH_CROSS_ORIGIN_COOKIES=false

# OpenRouter / DeepSeek (перефразирование и PDF)
OPENROUTER_API_KEY=
# OPENROUTER_API_BASE_URL=https://routerai.ru/api/v1
# OPENROUTER_HTTP_REFERER=https://mjimanager.ru
# OPENROUTER_X_TITLE=MJI Manager
# OPENROUTER_TIMEOUT_MS=300000

# --- Extension releases (optional for SSO) ---
INSTALLER_FILE_PATH=./installer/MJI-manager.exe
INSTALLER_RELEASES_DIR=./installer/releases
